{
  "name": "fets-monorepo",
  "private": true,
  "workspaces": [
    "website",
    "packages/*",
    "e2e/*",
    "examples/*",
    "benchmark"
  ],
  "packageManager": "npm@12.0.1",
  "scripts": {
    "build": "bob build",
    "ci:lint": "eslint . --output-file eslint_report.json --format json",
    "esm:check": "bob check",
    "generate-landing-page": "node ./packages/fets/scripts/generate-landing-page.cjs",
    "generate-swagger-ui": "node ./packages/fets/scripts/generate-swagger-ui.cjs",
    "lint": "eslint .",
    "postinstall": "patch-package && node ./scripts/shim-typescript7-api.cjs",
    "prebuild": "npm run generate-swagger-ui && npm run generate-landing-page",
    "precommit": "npx lint-staged",
    "prerelease": "npm run build",
    "prerelease-canary": "npm run build",
    "pretest": "npm run generate-swagger-ui && npm run generate-landing-page",
    "prets:check": "npm run generate-swagger-ui && npm run generate-landing-page",
    "prettier": "npm run prettier:check -- --write",
    "prettier:check": "npx prettier --ignore-path .gitignore --ignore-path .prettierignore --check .",
    "release": "changeset publish",
    "test": "jest --detectOpenHandles --detectLeaks",
    "test:integration": "cross-env \"INTEGRATION_TEST=true\" jest --detectOpenHandles --no-watchman",
    "ts:check": "tsc --noEmit",
    "version": "changeset version"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@babel/plugin-proposal-class-properties": "7.18.6",
    "@babel/preset-env": "7.29.7",
    "@babel/preset-typescript": "7.29.7",
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.1",
    "@eslint/js": "^10.0.1",
    "@theguild/prettier-config": "^3.0.1",
    "@types/jest": "30.0.0",
    "@types/js-yaml": "4.0.9",
    "@types/node": "26.1.1",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.65.0",
    "@typescript-eslint/parser": "8.65.0",
    "@typescript/typescript6": "6.0.2",
    "ansi-styles": "6.2.3",
    "babel-jest": "30.4.1",
    "bob-the-bundler": "7.0.1",
    "cookie": "2.0.1",
    "cross-env": "10.1.0",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "18.2.2",
    "eslint-plugin-tailwindcss": "3.18.3",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "js-yaml": "4.3.0",
    "lint-staged": "17.2.0",
    "patch-package": "8.0.1",
    "prettier": "3.9.6",
    "prettier-plugin-tailwindcss": "0.8.1",
    "rimraf": "6.1.3",
    "ts-jest": "29.4.12",
    "tslib": "2.8.1",
    "typescript": "7.0.2",
    "webpack": "5.108.4"
  },
  "overrides": {
    "@pulumi/pulumi": "3.253.0",
    "braces": "3.0.3",
    "cookie": "2.0.1",
    "diff": "9.0.0",
    "dompurify": "3.4.12",
    "esbuild": "0.28.1",
    "estree-util-value-to-estree": "3.5.0",
    "js-yaml": "4.3.0",
    "micromatch": "4.0.8",
    "next": "16.2.11",
    "prismjs": "1.30.0",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "tmp": "0.2.7",
    "webpack": "5.108.4"
  },
  "lint-staged": {
    "packages/**/*.{ts,tsx}": [
      "eslint --fix"
    ],
    "**/*.{ts,tsx,graphql,yml,md,mdx,js,json,html}": [
      "prettier --write"
    ]
  }
}
